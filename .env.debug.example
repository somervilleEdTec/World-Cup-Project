# Debug branch — local PC only (copy to .env on branch Debug)
# cp .env.debug.example .env

DEBUG_LOCAL=1
ALLOW_KO_SEED=1
RESULTS_MODE=none

# Local API + built SPA (Test-LocalSite.ps1 -Mode Serve)
VITE_API_BASE_URL=http://localhost:8787
PORT=8787

# Optional bootstrap admin override (defaults in auth.ts if unset)
# ADMIN_USERNAME=AdminTomsom
# ADMIN_PASSWORD=change-me-locally

# Do NOT set FOOTBALL_DATA_TOKEN on Debug — use npm run seed:debug for random results
# FOOTBALL_DATA_TOKEN=

# Do NOT set NODE_ENV=production locally (skips devDependencies on npm ci)
# NODE_ENV=production

# SQLite (default)
# SQLITE_PATH=data.db
