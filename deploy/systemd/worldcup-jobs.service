[Unit]
Description=World Cup Boys background jobs (locks + football-data sync)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/World-Cup-Project
EnvironmentFile=/home/ubuntu/World-Cup-Project/.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run jobs
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
