# Example: /etc/nginx/sites-available/worldcup
# All traffic → Node on :8787 (serves dist/ + /api). Do NOT use a separate static root
# for the SPA or you will keep serving an old build after deploy.
#
#   sudo cp deploy/nginx/worldcup.conf.example /etc/nginx/sites-available/worldcup
#   sudo ln -sf /etc/nginx/sites-available/worldcup /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;
    server_name worldcup.dosums.uk;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name worldcup.dosums.uk;

    # ssl_certificate /etc/letsencrypt/live/worldcup.dosums.uk/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/worldcup.dosums.uk/privkey.pem;

    # Rate limit login (optional — see worldcup-rate-limit.conf.snippet)
    # limit_req_zone $binary_remote_addr zone=wcb_login:10m rate=10r/m;

    location / {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # location = /api/auth/login {
    #     limit_req zone=wcb_login burst=5 nodelay;
    #     proxy_pass http://127.0.0.1:8787;
    #     ...
    # }
}
