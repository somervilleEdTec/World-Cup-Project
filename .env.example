# PostgreSQL (production). Omit to use SQLite at ./data.db
# DATABASE_URL=postgres://user:password@localhost:5432/worldcup_boys

# Required on main/production — live kickoffs + results from https://api.football-data.org/v4
# FOOTBALL_DATA_TOKEN=your_token_here

# Production mode (enforces token on server start; blocks KO test seeds unless ALLOW_KO_SEED=1)
# NODE_ENV=production

# Debug only — allow npm run seed:ko-environment / seed:before-final with fake data
# ALLOW_KO_SEED=1

# API port (default 8787)
# PORT=8787

# SQLite path when DATABASE_URL is unset
# SQLITE_PATH=data.db

# Production build + deploy: public HTTPS URL (required on server for npm run build)
# VITE_API_BASE_URL=https://your-domain.com

# Bootstrap admin (created on server start if missing)
# ADMIN_USERNAME=AdminTomsom
# ADMIN_PASSWORD=change-me-after-deploy
